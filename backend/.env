# ================================================================
# .env — Salon Management System (Meta WhatsApp Cloud API)
# ================================================================
# Copy this as your .env file in the backend/ folder.
# Fill in your actual values. No quotes. No spaces around =.
# After changing this file, restart: node server.js
# ================================================================

# ── SERVER ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MONGODB ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/salon_db

# ── META WHATSAPP CLOUD API ───────────────────────────────────────
#
# Where to get these — full instructions below.
# All three are REQUIRED for the bot to work.
#
# WHATSAPP_TOKEN: Your permanent access token
#   → developers.facebook.com → your app → WhatsApp → API Setup
#   → click "Generate access token" or use a System User token
#
WHATSAPP_TOKEN=EAAjbha53MAoBRh4CZBMOv2aqQvxXuZCKDZBV7cbERmIOrPpFGafNKzxQ9KE6pj3ZAO7zHaTlb7vtIsoIm94Md47BbUt13WyCiSFxRkROyGMRWbLM6FsH8M0kgrbfGbKVr27GGmZB7B1WTuKdm9qb7K3GtTQPIRDpqh6NT07eYL4acrSjtKKAeu3OTi1vx8prK7t7jYIqxsIP5iPAqa0zRabIPWhs8YKMZCEZAmZAhzUu
#
# WHATSAPP_PHONE_NUMBER_ID: The numeric ID of your phone number
#   → Same page as above, under "Phone Number ID"
#   → Example: 241594262382045
#   → This is NOT your phone number — it is a long number like that
#
WHATSAPP_PHONE_NUMBER_ID=1209934448859049
#
# WHATSAPP_VERIFY_TOKEN: A string YOU make up — any word or phrase
#   → You type this in the Meta webhook configuration form
#   → AND you put the same value here
#   → Example: salon_verify_2024 or mySalonSecret123
#   → Must match EXACTLY what you type in Meta dashboard
#
WHATSAPP_VERIFY_TOKEN=1427515995809697
#
# WHATSAPP_BUSINESS_ACCOUNT_ID: Your WhatsApp Business Account ID
#   → developers.facebook.com → your app → WhatsApp → API Setup
#   → Under "WhatsApp Business Account"
#   → Optional — only needed for some advanced API calls
#
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# ── SALON DETAILS ─────────────────────────────────────────────────
SALON_NAME=My Salon
SALON_PHONE=+919876543210
SALON_ADDRESS=123 MG Road, Your City, State
SALON_TIMEZONE=Asia/Kolkata
SALON_OPENING_HOUR=9
SALON_CLOSING_HOUR=20
SLOT_DURATION_MINUTES=30

# ── ADMIN DASHBOARD ───────────────────────────────────────────────
ADMIN_SECRET_KEY=your_admin_secret_key_here

# ── MARKETING AUTOMATION ──────────────────────────────────────────
INACTIVE_DAYS_TRIGGER=30
DISCOUNT_PERCENTAGE=10

# ── AI SMART REPLIES (optional) ───────────────────────────────────
# Get from: console.anthropic.com
# Leave blank to disable AI features
ANTHROPIC_API_KEY=

# ── TWILIO — DELETE THESE if they exist in your current .env ──────
# TWILIO_ACCOUNT_SID=   ← DELETE THIS LINE
# TWILIO_AUTH_TOKEN=    ← DELETE THIS LINE
# TWILIO_WHATSAPP_FROM= ← DELETE THIS LINE
